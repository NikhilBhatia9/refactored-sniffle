# Alpha Oracle 2.0 Configuration

# ── Supabase (required for TypeScript backend and frontend real-time data) ──────
# Get these from your Supabase project: Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-role-key-here  # Backend only – never expose to frontend

# ── External API Keys (optional – enables live market data) ──────────────────
# Get Alpha Vantage key at: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=

# Get FRED API key at: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# ── TypeScript Backend Settings ───────────────────────────────────────────────
NODE_ENV=development
PORT=8000

