# Backend API URL (optional)
# Leave empty to use proxy in development
# For production GitHub Pages deployment without a backend, leave empty
# For production with a deployed backend, set to your backend URL (e.g., https://api.example.com)
VITE_API_BASE_URL=

# Supabase (required for direct database access and real-time updates)
# Get these from your Supabase project: Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

